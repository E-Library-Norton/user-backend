# ─── Build & runtime artifacts ────────────────────────────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment secrets ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Version control ─────────────────────────────────────────────────────────
.git
.gitignore

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.DS_Store
.vscode
.idea
*.swp

# ─── Logs & uploads (runtime data, not part of image) ────────────────────────
logs/
uploads/backups/
# ─── Docker itself ────────────────────────────────────────────────────────────
Dockerfile
docker-compose*.yml
.dockerignore

# ─── Postman / docs ──────────────────────────────────────────────────────────
*.postman_collection.json
README.md
