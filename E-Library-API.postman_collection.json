{
  "info": {
    "name": "E-Library NU — Full API",
    "description": "Complete Postman collection for all E-Library API endpoints.\n\nBase URL: {{baseUrl}}  (default: http://localhost:5005)\n\nAuthentication:\n- After login, copy the `accessToken` from the response.\n- Set it in the collection variable `accessToken`.\n- All protected routes use Bearer token automatically via the collection auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "elibrary-nu-full-api-2026"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:5005",  "type": "string" },
    { "key": "accessToken", "value": "",                        "type": "string" },
    { "key": "userId",      "value": "1",                       "type": "string" },
    { "key": "bookId",      "value": "1",                       "type": "string" },
    { "key": "categoryId",  "value": "1",                       "type": "string" },
    { "key": "authorId",    "value": "1",                       "type": "string" },
    { "key": "publisherId", "value": "1",                       "type": "string" },
    { "key": "editorId",    "value": "1",                       "type": "string" },
    { "key": "roleId",      "value": "1",                       "type": "string" },
    { "key": "permId",      "value": "1",                       "type": "string" },
    { "key": "reviewId",    "value": "1",                       "type": "string" },
    { "key": "feedbackId",  "value": "1",                       "type": "string" },
    { "key": "deptId",      "value": "1",                       "type": "string" },
    { "key": "matTypeId",   "value": "1",                       "type": "string" }
