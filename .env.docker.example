# ══════════════════════════════════════════════════════════════════════════════
# Norton E-Library — Docker Environment Variables
# Copy this file:  cp .env.docker.example .env.docker
# Then fill in your real secrets below.
# Usage:  docker compose --env-file .env.docker up -d
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL (Docker container) ─────────────────────────────────────────────
POSTGRES_USER=elibrary
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=nu_elibrary_db
DB_PORT_EXTERNAL=5432

# ── SSL: set "false" for local Docker, "true" for Render / external DB ───────
DB_SSL=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5005

# ── Auth Secrets (generate strong random strings!) ────────────────────────────
ACCESS_TOKEN_SECRET=your-access-token-secret-here
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
ACCESS_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_EXPIRES_IN=60d
FORGOT_PASSWORD_SECRET=your-forgot-password-secret

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=elibrary-files
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=

# ── Email (Gmail SMTP) ──────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ── Google AI (Gemini) ──────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your-gemini-api-key

# ── Vector Search (optional) ─────────────────────────────────────────────────
VECTOR_SEARCH_SERVICE_URL=

# ── Web Push VAPID Keys (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@gmail.com
